{
  "server": "Reverse proxy",
  "services": [
    {
      "name":"user-service",
      "path": "api/users",
      "prefix": false,
      "instances": [
        {
          "url": "http://localhost:1001"
        },
        {
          "url": "http://localhost:1002"
        }
      ]
    },
    {
      "name": "order-service",
      "path":"api/orders",
      "prefix": false,
      "instances": [
        {
          "url": "http://localhost:2001"
        },
        {
          "url": "http://localhost:2002"
        }
      ]

    },
    {
      "name": "shipping-service",
      "path": "api/shipping",
      "prefix": false,
      "instances": [
        {
          "url": "http://localhost:3001"
        },
        {
          "url": "http://localhost:3002"
        }
      ]
    }

  ]

}